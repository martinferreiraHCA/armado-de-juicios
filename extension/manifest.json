{
  "manifest_version": 3,
  "name": "SIGED · Juicios con IA (Claude)",
  "description": "Genera juicios y promedios automáticos en la pantalla \"Cierre de promedios por alumno\" de SIGED usando la API de Claude.",
  "version": "0.2.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.siged.com.uy/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.siged.com.uy/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "SIGED · Juicios IA",
    "default_popup": "popup.html"
  }
}
